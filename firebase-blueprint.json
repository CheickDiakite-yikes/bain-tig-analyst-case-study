{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application (Bain Consultant/Partner)",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "consultant"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Deal": {
      "title": "Deal",
      "description": "A private equity tech due diligence deal room",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "targetCompany": { "type": "string" },
        "industry": { "type": "string" },
        "status": { "type": "string", "enum": ["sourcing", "diligence", "closed", "passed"] },
        "ev": { "type": "number", "description": "Enterprise Value in millions" },
        "aiMemory": { "type": "string", "description": "Persistent memory context for the AI analyst" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "targetCompany", "status", "createdBy", "createdAt"]
    },
    "File": {
      "title": "File",
      "description": "A file uploaded to a deal room (CIM, Data Room extract, etc.)",
      "type": "object",
      "properties": {
        "dealId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "size": { "type": "number" },
        "url": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "uploadedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["dealId", "name", "type", "size", "url", "uploadedBy", "uploadedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message in the AI Analyst thread for a deal",
      "type": "object",
      "properties": {
        "dealId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model", "system"] },
        "content": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["dealId", "role", "content", "createdAt"]
    },
    "Memo": {
      "title": "Memo",
      "description": "A generated due diligence memo or report",
      "type": "object",
      "properties": {
        "dealId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["dealId", "title", "content", "createdBy", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A due diligence task assigned to the AI analyst or a user",
      "type": "object",
      "properties": {
        "dealId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "in-progress", "done"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "assignedTo": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["dealId", "title", "status", "priority", "createdBy", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "deals/{dealId}": {
      "schema": "Deal",
      "description": "Deal rooms"
    },
    "files/{fileId}": {
      "schema": "File",
      "description": "Uploaded files metadata"
    },
    "messages/{messageId}": {
      "schema": "Message",
      "description": "AI Analyst chat history"
    },
    "memos/{memoId}": {
      "schema": "Memo",
      "description": "Generated DD memos"
    },
    "tasks/{taskId}": {
      "schema": "Task",
      "description": "Due diligence tasks"
    }
  }
}
